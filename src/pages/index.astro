---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Fundadora from '../components/Fundadora.astro';
import Manifesto from '../components/Manifesto.astro';
import BentoServicios from '../components/BentoServicios.astro';
import Galeria from '../components/Galeria.astro';
import Equipo from '../components/Equipo.astro';
import Precios from '../components/Precios.astro';
import Resenas from '../components/Resenas.astro';
import Mapa from '../components/Mapa.astro';
import Cta from '../components/Cta.astro';
import Footer from '../components/Footer.astro';
import Ornamento from '../components/Ornamento.astro';
---

<Base
  title="Ashley Pelegrin Beauty · Uñas acrílicas y manicura premium en Madrid · Villaverde"
  description="Salón especializado en uñas acrílicas, BabyBoomer, XXL, manicura semipermanente y pedicura en Calle Esperanza Macarena 14, Madrid. 4.9★ en 384 reseñas. Reserva en Booksy."
>
  <Nav />
  <main>
    <Hero />
    <Fundadora />
    <Manifesto />
    <Ornamento />
    <BentoServicios />
    <Galeria />
    <Equipo />
    <Precios />
    <Resenas />
    <Mapa />
    <Cta />
  </main>
  <Footer />
</Base>
