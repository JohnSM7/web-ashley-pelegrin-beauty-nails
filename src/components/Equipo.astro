---
import { equipo } from '../data/negocio';
---

<section id="equipo" class="relative overflow-hidden py-20 sm:py-28" style="background: var(--color-surface);">
  <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="mb-12 grid gap-6 sm:mb-16 md:grid-cols-12 md:gap-10">
      <div class="md:col-span-7 reveal-up">
        <p class="text-eyebrow text-[var(--color-primary)]">Tres manos, una firma</p>
        <h2 class="mt-3 text-display-lg text-text-dark">
          Las personas<br />
          <span class="italic" style="color: var(--color-primary);">detrás de la lima.</span>
        </h2>
      </div>
      <p class="md:col-span-5 self-end text-sm text-[var(--color-text-muted)] sm:text-base reveal-up">
        Las clientas las llaman por su nombre en cada reseña. Pide tu nail artist favorita al reservar
        o déjate sorprender por cualquiera de las tres.
      </p>
    </div>

    <div class="grid gap-6 sm:gap-7 md:grid-cols-3">
      {equipo.map((m, i) => (
        <article class="group relative reveal-up" style={`transition-delay: ${i * 80}ms;`}>
          <div class="relative mx-auto h-44 w-44 sm:h-48 sm:w-48">
            <!-- Ring rotativo -->
            <div class="team-ring absolute inset-0 rounded-full p-[3px]">
              <div class="h-full w-full rounded-full bg-[var(--color-surface)]"></div>
            </div>
            <!-- Inicial / medallón -->
            <div class="absolute inset-[6px] flex items-center justify-center rounded-full" style="background: linear-gradient(135deg, var(--color-primary-soft) 0%, var(--color-background) 100%);">
              <span class="font-display text-5xl text-[var(--color-text-dark)] sm:text-6xl">{m.iniciales}</span>
            </div>
          </div>

          <div class="mt-6 text-center">
            <h3 class="font-display text-2xl text-text-dark">
              {m.nombre} <span class="text-script text-3xl" style="color: var(--color-primary);">{m.apellido}</span>
            </h3>
            <p class="mt-1 text-eyebrow text-[var(--color-text-muted)]">{m.rol}</p>
            <p class="mx-auto mt-4 max-w-xs text-sm text-[var(--color-text-muted)] leading-relaxed">{m.bio}</p>
            <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] bg-[var(--color-background)] px-3 py-1.5">
              <span class="h-1.5 w-1.5 rounded-full" style="background: var(--color-accent-deep);"></span>
              <span class="text-[11px] text-[var(--color-text-dark)]">{m.especialidad}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
