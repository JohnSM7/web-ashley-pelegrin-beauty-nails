---
import { negocio } from '../data/negocio';
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden pt-20 pb-10 sm:pt-28" style="background: var(--color-dark-section); color: var(--color-text-light);">
  <div class="pointer-events-none absolute inset-x-0 -bottom-16 select-none text-center" aria-hidden="true">
    <span class="font-script block leading-none opacity-[0.08]" style="font-size: clamp(8rem, 28vw, 26rem); color: var(--color-accent);">Pelegrin</span>
  </div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-12 md:gap-12">
      <div class="md:col-span-5">
        <div class="flex items-center gap-3">
          <span class="grid h-12 w-12 overflow-hidden place-items-center rounded-full">
            <img src="/images/logo-marca.jpg" alt="" class="h-full w-full object-cover" width="48" height="48" />
          </span>
          <div>
            <p class="font-display text-xl text-[var(--color-text-light)]">Ashley Pelegrin</p>
            <p class="text-[10px] uppercase tracking-[0.18em] opacity-70">Beauty Nails · Madrid</p>
          </div>
        </div>
        <p class="mt-6 max-w-sm text-sm opacity-75">
          {negocio.descripcion}
        </p>
        <div class="mt-6 flex gap-2">
          <a href={negocio.redes.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="grid h-10 w-10 place-items-center rounded-full border border-white/15 hover:bg-white/10 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </a>
          <a href={negocio.redes.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="grid h-10 w-10 place-items-center rounded-full border border-white/15 hover:bg-white/10 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9 8H6v4h3v12h5V12h3.6l.4-4H14V6.3c0-1 .3-1.5 1.5-1.5H18V0h-3.4C10.7 0 9 1.7 9 5v3z"/>
            </svg>
          </a>
          <a href={negocio.redes.tiktok} target="_blank" rel="noopener" aria-label="TikTok" class="grid h-10 w-10 place-items-center rounded-full border border-white/15 hover:bg-white/10 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.6 6.3a4.8 4.8 0 01-3.8-2.3h-3v12.5a2.7 2.7 0 11-2.7-2.7c.4 0 .7.1 1 .2v-3a5.7 5.7 0 105 5.7V9.4a8 8 0 003.7 1.1V7.5c-.1 0-.2-.1-.2-.1-.5-.1-.7-.7-.7-1.1z"/>
            </svg>
          </a>
          <a href={negocio.redes.booksy} target="_blank" rel="noopener" aria-label="Booksy" class="ml-auto inline-flex items-center gap-1.5 rounded-full bg-[var(--color-accent)] px-4 py-2 text-xs font-medium text-[var(--color-text-dark)]">
            Reservar
          </a>
        </div>
      </div>

      <div class="md:col-span-3">
        <p class="text-eyebrow opacity-70 mb-4">Salón</p>
        <ul class="space-y-2 text-sm opacity-90">
          <li><a href="#servicios" class="hover:text-[var(--color-accent)] transition-colors">Servicios</a></li>
          <li><a href="#galeria" class="hover:text-[var(--color-accent)] transition-colors">Galería</a></li>
          <li><a href="#equipo" class="hover:text-[var(--color-accent)] transition-colors">Equipo</a></li>
          <li><a href="#precios" class="hover:text-[var(--color-accent)] transition-colors">Precios</a></li>
          <li><a href="#resenas" class="hover:text-[var(--color-accent)] transition-colors">Reseñas</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <p class="text-eyebrow opacity-70 mb-4">Contacto</p>
        <address class="not-italic space-y-2 text-sm opacity-90">
          <p>{negocio.direccion.calle}</p>
          <p>{negocio.direccion.cp} {negocio.direccion.ciudad} · España</p>
          <p><a href={negocio.telefonoLink} class="hover:text-[var(--color-accent)] transition-colors">{negocio.telefono}</a></p>
          <p><a href={`mailto:${negocio.email}`} class="hover:text-[var(--color-accent)] transition-colors">{negocio.email}</a></p>
        </address>

        <div class="mt-5 rounded-xl border border-white/10 p-4">
          <p class="text-eyebrow opacity-70">Horario</p>
          <p class="mt-1.5 text-sm">L–V <span class="opacity-70">10:00–20:00</span> · S <span class="opacity-70">10:00–14:00</span></p>
        </div>
      </div>
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-6 text-xs opacity-65 sm:flex-row sm:items-center">
      <p>© {year} {negocio.nombre}. Todos los derechos reservados.</p>
      <p>Hecho con ✦ en Madrid · Diseño & código a medida</p>
    </div>
  </div>
</footer>
