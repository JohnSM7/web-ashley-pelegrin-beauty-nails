---
import { negocio } from '../data/negocio';
---

<section id="contacto" class="relative overflow-hidden py-20 sm:py-28" style="background: var(--color-surface);">
  <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="mb-12 grid gap-6 md:grid-cols-12">
      <div class="md:col-span-7 reveal-up">
        <p class="text-eyebrow text-[var(--color-primary)]">Encuéntranos</p>
        <h2 class="mt-3 text-display-lg text-text-dark">
          A dos minutos<br />
          <span class="italic" style="color: var(--color-primary);">del metro</span> Los Rosales.
        </h2>
      </div>
      <div class="md:col-span-5 self-end space-y-4 text-sm text-[var(--color-text-muted)] reveal-up">
        <p>
          Estamos en {negocio.direccion.full}, en una callecita tranquila del barrio de
          Los Rosales (Villaverde). Aparcamiento gratuito en la zona.
        </p>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-12 md:gap-8">
      <!-- Datos -->
      <div class="md:col-span-5 reveal-up">
        <div class="rounded-3xl border border-[var(--color-line)] bg-[var(--color-background)] p-6 sm:p-8">
          <dl class="space-y-6">
            <div>
              <dt class="text-eyebrow text-[var(--color-primary)]">Dirección</dt>
              <dd class="mt-2 font-display text-xl text-[var(--color-text-dark)]">{negocio.direccion.calle}</dd>
              <dd class="text-sm text-[var(--color-text-muted)]">{negocio.direccion.cp} · {negocio.direccion.ciudad} · {negocio.barrio}</dd>
            </div>

            <div class="hairline"></div>

            <div>
              <dt class="text-eyebrow text-[var(--color-primary)]">Teléfono</dt>
              <dd class="mt-2"><a href={negocio.telefonoLink} class="font-display text-xl text-[var(--color-text-dark)] underline-offset-4 hover:underline">{negocio.telefono}</a></dd>
            </div>

            <div class="hairline"></div>

            <div>
              <dt class="text-eyebrow text-[var(--color-primary)]">Horario</dt>
              <dd class="mt-2 grid grid-cols-2 gap-x-3 gap-y-1.5 text-sm">
                {negocio.horario.map((h) => (
                  <Fragment>
                    <span class="text-[var(--color-text-dark)]">{h.dia}</span>
                    <span class={`tabular-nums ${h.abre ? 'text-[var(--color-text-muted)]' : 'text-[var(--color-text-muted)]/70'}`}>
                      {h.abre ? `${h.abre} – ${h.cierra}` : 'Cerrado'}
                    </span>
                  </Fragment>
                ))}
              </dd>
            </div>

            <div class="hairline"></div>

            <div class="flex flex-wrap gap-2">
              <a href={negocio.booking} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full bg-[var(--color-text-dark)] px-4 py-2.5 text-xs font-medium text-[var(--color-text-light)] hover:bg-[var(--color-primary)] transition-colors">
                Reservar Booksy
              </a>
              <a href={negocio.whatsappLink} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-text-dark)] px-4 py-2.5 text-xs font-medium text-[var(--color-text-dark)] hover:bg-[var(--color-text-dark)] hover:text-[var(--color-text-light)] transition-colors">
                WhatsApp
              </a>
              <a href={`https://www.google.com/maps/dir/?api=1&destination=${negocio.geo.lat},${negocio.geo.lng}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full border border-[var(--color-line)] px-4 py-2.5 text-xs font-medium text-[var(--color-text-dark)] hover:border-[var(--color-text-dark)] transition-colors">
                Cómo llegar
              </a>
            </div>
          </dl>
        </div>
      </div>

      <!-- Mapa -->
      <div class="md:col-span-7 reveal-up">
        <div id="mapWrapper" class="relative h-[420px] w-full overflow-hidden rounded-3xl sm:h-[480px] md:h-full md:min-h-[520px]">
          <div id="mapSkeleton" class="absolute inset-0 z-10 grid place-items-center skeleton-shimmer">
            <div class="flex flex-col items-center gap-3">
              <div class="h-6 w-6 animate-spin rounded-full border-2 border-[var(--color-text-dark)] border-t-transparent"></div>
              <p class="text-xs text-[var(--color-text-muted)]">Cargando mapa...</p>
            </div>
          </div>
          <div id="map" class="absolute inset-0"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  import L from 'leaflet';

  const lat = 40.3503386;
  const lng = -3.6905645;

  function initMap() {
    const skeleton = document.getElementById('mapSkeleton');
    const el = document.getElementById('map');
    if (!el) return;

    const map = L.map(el, {
      center: [lat, lng],
      zoom: 16,
      scrollWheelZoom: false,
      zoomControl: true,
    });

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap',
      maxZoom: 19,
    }).addTo(map);

    // Pin SVG personalizado con monograma AP
    const pinHtml = `
      <div style="position:relative;width:48px;height:60px;">
        <svg width="48" height="60" viewBox="0 0 48 60" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="pinGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="oklch(0.74 0.11 75)"/>
              <stop offset="100%" stop-color="oklch(0.56 0.13 60)"/>
            </linearGradient>
          </defs>
          <path d="M24 0C10.7 0 0 10.7 0 24c0 17 24 36 24 36s24-19 24-36C48 10.7 37.3 0 24 0z" fill="url(#pinGrad)"/>
          <circle cx="24" cy="24" r="14" fill="oklch(0.16 0.018 25)"/>
          <text x="24" y="29" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="14" font-weight="500" fill="oklch(0.96 0.008 60)">AP</text>
        </svg>
      </div>
    `;
    const icon = L.divIcon({
      html: pinHtml,
      className: 'custom-pin',
      iconSize: [48, 60],
      iconAnchor: [24, 60],
      popupAnchor: [0, -56],
    });

    L.marker([lat, lng], { icon })
      .addTo(map)
      .bindPopup(
        '<strong style="font-family:Fraunces,serif;font-size:16px;">Ashley Pelegrin Beauty</strong><br/><span style="font-size:12px;color:#666;">Calle Esperanza Macarena 14</span>',
      );

    // Reveal map
    setTimeout(() => {
      skeleton?.classList.add('opacity-0');
      setTimeout(() => skeleton?.remove(), 400);
    }, 600);
  }

  // Carga diferida con IntersectionObserver
  const wrapper = document.getElementById('mapWrapper');
  if (wrapper && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            initMap();
            io.disconnect();
          }
        });
      },
      { rootMargin: '200px' },
    );
    io.observe(wrapper);
  } else {
    initMap();
  }
</script>

<style is:global>
  #mapSkeleton {
    transition: opacity 0.4s ease;
  }
  .custom-pin {
    background: transparent !important;
    border: none !important;
  }
  .leaflet-popup-content-wrapper {
    border-radius: 12px !important;
    background: oklch(0.985 0.008 60) !important;
  }
  .leaflet-popup-tip {
    background: oklch(0.985 0.008 60) !important;
  }
</style>
