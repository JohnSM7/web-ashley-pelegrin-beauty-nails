---
import { stats } from '../data/negocio';
---

<section class="relative overflow-hidden py-20 sm:py-28 lg:py-36" style="background: var(--color-surface);">
  <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="grid items-end gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-7 reveal-up">
        <p class="text-eyebrow text-[var(--color-primary)]">Manifiesto · 2019 → hoy</p>
        <h2 class="mt-4 text-display-lg text-text-dark">
          No vendemos uñas.<br />
          <span class="italic" style="color: var(--color-primary);">Esculpimos calma</span>
          <br />durante <span class="text-script" style="font-size: 1.4em; color: var(--color-accent-deep);">90 minutos</span>.
        </h2>
        <p class="mt-7 max-w-2xl text-base leading-relaxed text-[var(--color-text-muted)] sm:text-lg">
          Cada cita es un ritual: té, conversación, lima, base, color, remate y un brillo final
          que te acompaña tres semanas. Trabajamos con producto profesional, sin prisas y con la
          tranquilidad de quien ya tiene a 384 clientas que vuelven cada mes.
        </p>
      </div>

      <div class="lg:col-span-5 reveal-up">
        <blockquote class="border-l-2 pl-6" style="border-color: var(--color-primary);">
          <p class="font-display text-xl italic leading-snug text-[var(--color-text-dark)] sm:text-2xl">
            "He probado en mil sitios hasta que encontré este y a Fernanda."
          </p>
          <footer class="mt-3 text-sm text-[var(--color-text-muted)]">
            — Pilar, abril 2026 · reseña verificada en Booksy
          </footer>
        </blockquote>
      </div>
    </div>

    <!-- Stats -->
    <dl class="mt-16 grid grid-cols-2 gap-px overflow-hidden rounded-2xl bg-[var(--color-line)] sm:mt-20 md:grid-cols-4">
      {stats.map((s) => (
        <div class="flex flex-col gap-1 bg-[var(--color-surface)] p-6 sm:p-8 reveal-up">
          <dt class="text-eyebrow text-[var(--color-text-muted)]">{s.etiqueta}</dt>
          <dd class="font-display text-4xl text-[var(--color-text-dark)] sm:text-5xl">
            {s.valor.startsWith('+') || s.valor.includes('%') ? (
              <span>{s.valor}</span>
            ) : (
              <span class="text-gradient-gold">{s.valor}</span>
            )}
          </dd>
          <dd class="mt-1 text-xs text-[var(--color-text-muted)] sm:text-sm">{s.detalle}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
