---
import { resenas, negocio } from '../data/negocio';
const half = Math.ceil(resenas.length / 2);
const fila1 = resenas.slice(0, half);
const fila2 = resenas.slice(half);
---

<section id="resenas" class="relative overflow-hidden py-20 sm:py-28" style="background: var(--color-background);">
  <div class="mx-auto mb-14 max-w-7xl px-5 sm:mb-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-12">
      <div class="md:col-span-7 reveal-up">
        <p class="text-eyebrow text-[var(--color-primary)]">Lo que dicen</p>
        <h2 class="mt-3 text-display-lg text-text-dark">
          <span class="text-gradient-gold">{negocio.rating.valor}</span> sobre 5 ·<br />
          <span class="italic" style="color: var(--color-primary);">{negocio.rating.total} clientas</span> lo confirman.
        </h2>
      </div>
      <p class="md:col-span-5 self-end text-sm text-[var(--color-text-muted)] sm:text-base reveal-up">
        Todas las reseñas son verificadas en Booksy, donde solo puede opinar quien realmente ha venido.
        Aquí no maquillamos las puntuaciones.
      </p>
    </div>
  </div>

  <!-- Marquee Fila 1 -->
  <div class="marquee-mask overflow-hidden">
    <div class="marquee-track flex gap-4 sm:gap-5">
      {[...fila1, ...fila1].map((r) => (
        <article class="w-[300px] flex-none rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-5 sm:w-[360px] sm:p-6">
          <div class="flex items-center gap-1 mb-3">
            {Array.from({ length: r.rating }).map(() => (
              <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" style="color: var(--color-accent-deep);" aria-hidden="true">
                <path d="M10 1l2.6 5.27 5.82.85-4.21 4.1.99 5.78L10 14.27 4.8 17l.99-5.78L1.58 7.12l5.82-.85L10 1z"/>
              </svg>
            ))}
          </div>
          <p class="font-display text-base leading-snug text-[var(--color-text-dark)] sm:text-lg">
            "{r.texto}" {'emoji' in r && r.emoji ? <span>{r.emoji}</span> : null}
          </p>
          <footer class="mt-4 flex items-center justify-between text-xs text-[var(--color-text-muted)]">
            <span class="font-medium text-[var(--color-text-dark)]">— {r.autor}</span>
            <span>{r.fecha}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>

  <!-- Marquee Fila 2 (reverso) -->
  <div class="marquee-mask mt-5 overflow-hidden sm:mt-6">
    <div class="marquee-track-rev flex gap-4 sm:gap-5">
      {[...fila2, ...fila2].map((r) => (
        <article class="w-[300px] flex-none rounded-2xl p-5 sm:w-[360px] sm:p-6" style="background: var(--color-primary-soft); color: var(--color-text-dark);">
          <div class="flex items-center gap-1 mb-3">
            {Array.from({ length: r.rating }).map(() => (
              <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" style="color: var(--color-accent-deep);" aria-hidden="true">
                <path d="M10 1l2.6 5.27 5.82.85-4.21 4.1.99 5.78L10 14.27 4.8 17l.99-5.78L1.58 7.12l5.82-.85L10 1z"/>
              </svg>
            ))}
          </div>
          <p class="font-display text-base leading-snug sm:text-lg">"{r.texto}"</p>
          <footer class="mt-4 flex items-center justify-between text-xs opacity-70">
            <span class="font-medium">— {r.autor}</span>
            <span>{r.fecha}</span>
          </footer>
        </article>
      ))}
    </div>
  </div>

  <div class="mt-12 flex justify-center sm:mt-14">
    <a
      href={negocio.booking}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 rounded-full border border-[var(--color-text-dark)] px-5 py-3 text-sm font-medium text-[var(--color-text-dark)] transition-colors hover:bg-[var(--color-text-dark)] hover:text-[var(--color-text-light)]"
    >
      Ver las 384 reseñas en Booksy
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</section>
