---
import { negocio } from '../data/negocio';
---

<header class="fixed inset-x-0 top-0 z-50 glass-nav">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-3.5 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center gap-2.5" aria-label={negocio.nombre}>
      <span
        class="grid h-9 w-9 overflow-hidden place-items-center rounded-full sm:h-10 sm:w-10"
      >
        <img src="/images/logo-marca.jpg" alt="" class="h-full w-full object-cover" width="40" height="40" />
      </span>
      <span class="flex flex-col leading-none">
        <span class="font-display text-base sm:text-[17px] text-text-dark">Ashley Pelegrin</span>
        <span class="text-[10px] tracking-[0.18em] uppercase text-[var(--color-text-muted)]">Beauty Nails</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Navegación principal">
      <a href="#fundadora" class="text-sm text-text-dark hover:text-[var(--color-accent-deep)] transition-colors">Ashley</a>
      <a href="#servicios" class="text-sm text-text-dark hover:text-[var(--color-accent-deep)] transition-colors">Servicios</a>
      <a href="#galeria" class="text-sm text-text-dark hover:text-[var(--color-accent-deep)] transition-colors">Galería</a>
      <a href="#equipo" class="text-sm text-text-dark hover:text-[var(--color-accent-deep)] transition-colors">Equipo</a>
      <a href="#precios" class="text-sm text-text-dark hover:text-[var(--color-accent-deep)] transition-colors">Precios</a>
      <a href="#resenas" class="text-sm text-text-dark hover:text-[var(--color-accent-deep)] transition-colors">Reseñas</a>
      <a href="#contacto" class="text-sm text-text-dark hover:text-[var(--color-accent-deep)] transition-colors">Contacto</a>
    </nav>

    <a
      href={negocio.booking}
      target="_blank"
      rel="noopener"
      class="magnetic inline-flex items-center gap-2 rounded-full bg-[var(--color-text-dark)] px-4 py-2.5 text-xs font-medium tracking-wide text-[var(--color-text-light)] transition-colors hover:bg-[var(--color-primary)] sm:px-5 sm:text-[13px]"
    >
      <span class="hidden sm:inline">Reservar cita</span>
      <span class="sm:hidden">Reservar</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</header>
