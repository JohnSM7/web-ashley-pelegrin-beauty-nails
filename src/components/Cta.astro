---
import { negocio } from '../data/negocio';
---

<section class="relative overflow-hidden py-20 sm:py-28" style="background: var(--color-background);">
  <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div
      class="relative overflow-hidden rounded-[28px] p-8 text-center sm:p-12 md:p-16"
      style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent-deep) 100%); color: var(--color-text-light);"
    >
      <span class="ghost-script pointer-events-none absolute -bottom-12 left-1/2 -translate-x-1/2 select-none text-[14rem] opacity-30 sm:text-[18rem]" style="-webkit-text-stroke: 1px color-mix(in oklab, white 30%, transparent);">cita</span>

      <div class="relative mx-auto max-w-2xl reveal-up">
        <p class="text-eyebrow opacity-85">Tu próxima cita</p>
        <h2 class="mt-3 text-display-lg">
          ¿Lista para unas <span class="italic text-script" style="font-size: 1.5em;">manos</span> que te miren bien?
        </h2>
        <p class="mt-5 text-sm opacity-85 sm:text-base">
          Reserva en Booksy o escríbenos por WhatsApp. Confirmamos tu cita en menos de 30 minutos durante el horario del salón.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-3 sm:gap-4">
          <a
            href={negocio.booking}
            target="_blank"
            rel="noopener"
            class="magnetic inline-flex items-center gap-2 rounded-full bg-[var(--color-text-light)] px-6 py-4 text-sm font-medium text-[var(--color-text-dark)] transition-transform hover:scale-[1.02]"
          >
            Reservar en Booksy
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href={negocio.whatsappLink}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full border border-white/35 px-6 py-4 text-sm font-medium text-[var(--color-text-light)] backdrop-blur hover:bg-white/10"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/>
            </svg>
            WhatsApp directo
          </a>
        </div>

        <p class="mt-7 text-xs opacity-70">
          o llámanos al <a href={negocio.telefonoLink} class="font-medium underline underline-offset-4">{negocio.telefono}</a>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Sticky WhatsApp en todos los viewports — color cobre de marca -->
<a
  href={negocio.whatsappLink}
  target="_blank"
  rel="noopener"
  class="group fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full pl-2 pr-5 py-2 shadow-xl transition-all hover:scale-[1.04] hover:shadow-2xl sm:bottom-6 sm:right-6"
  style="background: var(--color-accent-deep); color: var(--color-text-light);"
  aria-label="Escribir por WhatsApp"
>
  <span class="relative grid h-10 w-10 place-items-center rounded-full bg-white/15">
    <span class="pulse-dot absolute inset-0 rounded-full bg-white/25"></span>
    <svg viewBox="0 0 32 32" width="22" height="22" fill="currentColor" aria-hidden="true" class="relative">
      <path d="M16.003 0C7.174 0 .01 7.163.01 15.992c0 2.819.736 5.572 2.135 8.001L0 32l8.234-2.157a15.967 15.967 0 0 0 7.768 1.978h.007C24.836 31.821 32 24.659 32 15.83 32 7 24.836 0 16.003 0Zm9.343 22.602c-.396 1.107-2.291 2.118-3.197 2.252-.815.121-1.84.171-2.967-.187-.685-.218-1.564-.51-2.692-.997-4.736-2.045-7.829-6.811-8.064-7.126-.235-.314-1.926-2.561-1.926-4.886 0-2.324 1.22-3.467 1.654-3.94.434-.473.946-.591.946-.591.394-.018.787-.014 1.122.003.359.018.84-.137 1.314.999.483 1.155 1.638 3.99 1.782 4.282.143.291.236.628.041.999-.196.371-.295.602-.578.926-.283.324-.595.724-.85.973-.282.275-.575.572-.247 1.125.328.553 1.46 2.41 3.135 3.905 2.151 1.92 3.97 2.514 4.521 2.79.55.276.873.231 1.196-.139.323-.37 1.379-1.615 1.747-2.169.367-.554.736-.462 1.241-.276.506.185 3.21 1.514 3.762 1.789.553.275.921.41 1.06.642.137.231.137 1.337-.26 2.443Z"/>
    </svg>
  </span>
  <span class="hidden text-[13px] font-medium whitespace-nowrap sm:inline">Escríbeme</span>
</a>
