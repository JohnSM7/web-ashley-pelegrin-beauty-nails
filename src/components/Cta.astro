---
import { negocio } from '../data/negocio';
---

<section class="relative overflow-hidden py-20 sm:py-28" style="background: var(--color-background);">
  <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div
      class="relative overflow-hidden rounded-[28px] p-8 text-center sm:p-12 md:p-16"
      style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent-deep) 100%); color: var(--color-text-light);"
    >
      <span class="ghost-script pointer-events-none absolute -bottom-12 left-1/2 -translate-x-1/2 select-none text-[14rem] opacity-30 sm:text-[18rem]" style="-webkit-text-stroke: 1px color-mix(in oklab, white 30%, transparent);">cita</span>

      <div class="relative mx-auto max-w-2xl reveal-up">
        <p class="text-eyebrow opacity-85">Tu próxima cita</p>
        <h2 class="mt-3 text-display-lg">
          ¿Lista para unas <span class="italic text-script" style="font-size: 1.5em;">manos</span> que te miren bien?
        </h2>
        <p class="mt-5 text-sm opacity-85 sm:text-base">
          Reserva en Booksy o escríbenos por WhatsApp. Confirmamos tu cita en menos de 30 minutos durante el horario del salón.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-3 sm:gap-4">
          <a
            href={negocio.booking}
            target="_blank"
            rel="noopener"
            class="magnetic inline-flex items-center gap-2 rounded-full bg-[var(--color-text-light)] px-6 py-4 text-sm font-medium text-[var(--color-text-dark)] transition-transform hover:scale-[1.02]"
          >
            Reservar en Booksy
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href={negocio.whatsappLink}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full border border-white/35 px-6 py-4 text-sm font-medium text-[var(--color-text-light)] backdrop-blur hover:bg-white/10"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
            </svg>
            WhatsApp directo
          </a>
        </div>

        <p class="mt-7 text-xs opacity-70">
          o llámanos al <a href={negocio.telefonoLink} class="font-medium underline underline-offset-4">{negocio.telefono}</a>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Sticky WhatsApp en todos los viewports — color cobre de marca -->
<a
  href={negocio.whatsappLink}
  target="_blank"
  rel="noopener"
  class="group fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full pl-2 pr-5 py-2 shadow-xl transition-all hover:scale-[1.04] hover:shadow-2xl sm:bottom-6 sm:right-6"
  style="background: var(--color-accent-deep); color: var(--color-text-light);"
  aria-label="Escribir por WhatsApp"
>
  <span class="relative grid h-10 w-10 place-items-center rounded-full bg-white shadow-inner">
    <span class="pulse-dot absolute inset-0 rounded-full bg-white/40"></span>
    <svg viewBox="-1 -1 26 26" width="24" height="24" aria-hidden="true" class="relative" style="color: var(--color-accent-deep);">
      <path fill="currentColor" d="M19.05 4.91A9.816 9.816 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01zM12.04 20.15c-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.264 8.264 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24 2.2 0 4.27.86 5.82 2.42a8.183 8.183 0 0 1 2.41 5.83c.02 4.54-3.68 8.23-8.22 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.17.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43s.17-.25.25-.41c.08-.17.04-.31-.02-.43s-.56-1.34-.76-1.84c-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18s-.22-.16-.47-.28z"/>
    </svg>
  </span>
  <span class="hidden text-[13px] font-medium whitespace-nowrap sm:inline">Escríbeme</span>
</a>
