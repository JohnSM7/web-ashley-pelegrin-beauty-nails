---
import { servicios, negocio } from '../data/negocio';
---

<section id="precios" class="relative overflow-hidden py-20 sm:py-28 lg:py-36" style="background: var(--color-dark-section); color: var(--color-text-light);">
  <!-- Ornamento script de fondo -->
  <div class="pointer-events-none absolute -right-12 top-4 select-none opacity-[0.06]" aria-hidden="true">
    <span class="font-script text-[14rem] leading-none lg:text-[20rem]" style="color: var(--color-accent);">precios</span>
  </div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="mb-14 grid gap-6 md:grid-cols-12">
      <div class="md:col-span-7 reveal-up">
        <p class="text-eyebrow" style="color: var(--color-accent);">Carta completa</p>
        <h2 class="mt-3 text-display-lg" style="color: var(--color-text-light);">
          Precios claros,<br />
          <span class="italic text-gradient-gold">sin sorpresas.</span>
        </h2>
      </div>
      <div class="md:col-span-5 self-end space-y-3 reveal-up">
        <p class="text-sm opacity-75 sm:text-base">
          Todos los servicios incluyen retirada de esmalte previo, lima y aceite de cutícula.
          Los precios marcados como "Desde" varían según largo y diseño.
        </p>
        <a
          href={negocio.booking}
          target="_blank"
          rel="noopener"
          class="magnetic inline-flex items-center gap-2 rounded-full px-5 py-3 text-sm font-medium text-[var(--color-text-dark)] transition-opacity hover:opacity-90"
          style="background: var(--color-accent);"
        >
          Ver disponibilidad
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>

    <div class="grid gap-8 md:grid-cols-2 md:gap-x-16 md:gap-y-14">
      {servicios.map((cat, i) => (
        <div class="reveal-up" style={`transition-delay: ${i * 60}ms;`}>
          <div class="mb-5 flex items-baseline gap-3">
            <span class="font-display text-3xl text-gradient-gold">0{i + 1}</span>
            <h3 class="font-display text-2xl" style="color: var(--color-text-light);">{cat.categoria}</h3>
          </div>
          <p class="mb-5 text-sm opacity-65">{cat.descripcion}</p>
          <ul class="space-y-3">
            {cat.items.map((it) => (
              <li class="group flex items-baseline gap-3">
                <span class={`text-sm sm:text-[15px] ${it.destacado ? 'font-medium' : 'opacity-90'}`}>
                  {it.nombre}
                  {it.destacado && <span class="ml-2 align-middle text-[9px] uppercase tracking-wider rounded-full px-1.5 py-0.5" style="background: color-mix(in oklab, var(--color-accent) 18%, transparent); color: var(--color-accent);">Top</span>}
                </span>
                <span class="flex-1 border-b border-dotted border-white/15 translate-y-[-3px]"></span>
                <span class="flex items-baseline gap-1 font-display text-base tabular-nums" style="color: var(--color-accent);">
                  {it.desde}<span class="text-xs opacity-70">€</span>
                </span>
                <span class="hidden text-[11px] opacity-55 sm:inline-block sm:w-16 sm:text-right">{it.duracion}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 rounded-2xl border border-white/10 p-6 sm:p-8 md:flex md:items-center md:justify-between md:gap-8 reveal-up">
      <div>
        <p class="font-display text-xl sm:text-2xl" style="color: var(--color-text-light);">¿No estás segura del servicio?</p>
        <p class="mt-1 text-sm opacity-70">Cuéntanos por WhatsApp y te recomendamos el plan ideal en 5 minutos.</p>
      </div>
      <a
        href={negocio.whatsappLink}
        target="_blank"
        rel="noopener"
        class="mt-5 inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-5 py-3 text-sm font-medium text-[var(--color-text-dark)] md:mt-0"
      >
        Pregúntanos por WhatsApp
      </a>
    </div>
  </div>
</section>
